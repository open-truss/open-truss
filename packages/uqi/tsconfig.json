{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist/cjs"
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"],
  "include": ["./src/**/*.ts"]
}
