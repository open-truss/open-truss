{
  "compilerOptions": {
    "target": "ES2018",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist/cjs",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"],
  "include": ["./src/**/*.ts", "./src/**/*.tsx"]
}
